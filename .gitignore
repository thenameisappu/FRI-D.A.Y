# =============================================================================
# FRI-D.A.Y — .gitignore
# Python | Windows | VS Code / PyCharm
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets & Environment
# -----------------------------------------------------------------------------
.env
*.env
!.env.example

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Distributions / packaging
dist/
build/
*.egg-info/
*.egg
MANIFEST

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/

# Unit test / coverage
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
nosetests.xml

# Jupyter notebooks (checkpoints)
.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# Virtual Environments
# -----------------------------------------------------------------------------
venv/
.venv/
env/
ENV/
Lib/
Scripts/
pyvenv.cfg

# -----------------------------------------------------------------------------
# IDE & Editor
# -----------------------------------------------------------------------------
# VS Code
.vscode/
*.code-workspace

# PyCharm / JetBrains
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Spyder
.spyderproject.cfg
.spyproject/

# -----------------------------------------------------------------------------
# Windows
# -----------------------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# -----------------------------------------------------------------------------
# Logs & Databases
# -----------------------------------------------------------------------------
*.log
*.sqlite3
*.db
logs/

# -----------------------------------------------------------------------------
# Audio / Video / Model Caches (generated at runtime)
# -----------------------------------------------------------------------------
*.wav
*.mp3
*.mp4
*.avi
*.pkl
*.h5
*.pt
*.pth
*.onnx

# Wake word / Porcupine access key (keep out of VCS)
*.ppn

# -----------------------------------------------------------------------------
# Pygame / OpenCV runtime artifacts
# -----------------------------------------------------------------------------
*.pyc
*.spec

# PyInstaller output
dist/
build/

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.DS_Store
*.bak
*.swp
*.tmp
~$*
